{
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist/types",
    "strict": true,
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false
  }
}
